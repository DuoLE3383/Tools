/**
 * For more details on how to configure Wrangler, refer to:
 * https://developers.cloudflare.com/workers/wrangler/configuration/
 */
{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "tools",
	"main": "worker/index.js",
	"compatibility_date": "2026-05-26",
	"assets": {
		"directory": "./dist",
		"not_found_handling": "single-page-application"
	},
	"observability": {
		"enabled": true
	},
	"upload_source_maps": true,
	"compatibility_flags": [
		"nodejs_compat"
	],
	"vars": {
		"NICEHASH_API_KEY": "",
		"NICEHASH_API_SECRET": "",
		"NICEHASH_ORG_ID": "",
		"NICEHASH_ENVIRONMENT": "production",
		"MRR_KEY_RIG_BT": "",
		"MRR_SECRET_RIG_BT": "",
		"MRR_KEY_RIG_SL": "",
		"MRR_SECRET_RIG_SL": "",
		"TUNNEL_URL": "https://these-bacterial-italiano-pavilion.trycloudflare.com"
	},
	"kv_namespaces": [
		{
			"binding": "server",
			"id": "0f1ddf5ff91d400dad8cfb3c316bfa1e",
			"remote": true
		}
	],
}